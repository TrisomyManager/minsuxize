@model MinsuXize.Web.ViewModels.SubmitEntryViewModel

<section class="page-header">
    <nav class="breadcrumb-line" aria-label="面包屑">
        <a asp-controller="Home" asp-action="Index">首页</a>
        <span>/</span>
        <span>投稿</span>
    </nav>
    <span class="eyebrow">Submit</span>
    <h1>投稿与纠错</h1>
    <p>可提交新词条、补充流程、地区差异、禁忌、来源线索，或指出现有词条中的错误。提交后会进入待核实状态。</p>
    @if (!string.IsNullOrWhiteSpace(Model.RelatedEntryTitle))
    {
        <div class="meta-list">
            <span>关联词条：@Model.RelatedEntryTitle</span>
        </div>
    }
</section>

<section class="content-section form-shell">
    <form asp-action="Create" method="post" class="entry-form">
        @Html.AntiForgeryToken()
        <input asp-for="RelatedEntryId" type="hidden" />
        <input asp-for="RelatedEntryTitle" type="hidden" />

        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="form-grid">
            <div class="field-group">
                <label asp-for="ContributorName"></label>
                <input asp-for="ContributorName" class="field-input" />
                <span asp-validation-for="ContributorName" class="field-error"></span>
            </div>
            <div class="field-group">
                <label asp-for="Contact"></label>
                <input asp-for="Contact" class="field-input" placeholder="邮箱、微信或其他联系方式，可选" />
                <span asp-validation-for="Contact" class="field-error"></span>
            </div>
            <div class="field-group">
                <label asp-for="ContentType"></label>
                <select asp-for="ContentType" asp-items="Model.ContentTypes" class="field-input"></select>
            </div>
            <div class="field-group">
                <label asp-for="RegionId"></label>
                <select asp-for="RegionId" asp-items="Model.Regions" class="field-input">
                    <option value="">请选择地区</option>
                </select>
                <span asp-validation-for="RegionId" class="field-error"></span>
            </div>
            <div class="field-group">
                <label asp-for="FestivalId"></label>
                <select asp-for="FestivalId" asp-items="Model.Festivals" class="field-input">
                    <option value="">请选择节日或时间节点</option>
                </select>
                <span asp-validation-for="FestivalId" class="field-error"></span>
            </div>
            <div class="field-group">
                <label asp-for="Title"></label>
                <input asp-for="Title" class="field-input" />
                <span asp-validation-for="Title" class="field-error"></span>
            </div>
        </div>

        <div class="field-group">
            <label asp-for="Summary"></label>
            <textarea asp-for="Summary" class="field-input" placeholder="请尽量说明地点、时间、参与者、流程、材料、禁忌或差异。"></textarea>
            <span asp-validation-for="Summary" class="field-error"></span>
        </div>

        <div class="field-group">
            <label asp-for="SourceSummary"></label>
            <textarea asp-for="SourceSummary" class="field-input" placeholder="例如：本人亲历、长辈口述、田野笔记、地方志、公开网页、照片/视频等。"></textarea>
            <span asp-validation-for="SourceSummary" class="field-error"></span>
        </div>

        <div class="form-section">
            <h2>可选补充</h2>
            <div class="form-grid">
                <div class="field-group">
                    <label asp-for="ImagesInput"></label>
                    <input asp-for="ImagesInput" class="field-input" placeholder="多个链接用英文逗号分隔" />
                </div>
                <div class="field-group">
                    <label asp-for="VideosInput"></label>
                    <input asp-for="VideosInput" class="field-input" placeholder="多个链接用英文逗号分隔" />
                </div>
                <div class="field-group">
                    <label asp-for="AudiosInput"></label>
                    <input asp-for="AudiosInput" class="field-input" placeholder="多个链接用英文逗号分隔" />
                </div>
                <div class="field-group">
                    <label asp-for="ChangeLog"></label>
                    <input asp-for="ChangeLog" class="field-input" placeholder="本次补充的重点" />
                </div>
                <div class="field-group">
                    <label asp-for="Latitude"></label>
                    <input asp-for="Latitude" class="field-input" />
                </div>
                <div class="field-group">
                    <label asp-for="Longitude"></label>
                    <input asp-for="Longitude" class="field-input" />
                </div>
            </div>
            <div class="field-group">
                <label asp-for="Address"></label>
                <input asp-for="Address" class="field-input" />
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="button-primary">提交</button>
            <a class="button-secondary" asp-controller="Home" asp-action="SubmissionGuidelines">查看提交说明</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
