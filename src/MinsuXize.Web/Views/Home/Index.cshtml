@model MinsuXize.Web.ViewModels.HomePageViewModel

<section class="knowledge-hero" aria-label="中国民俗细则知识入口">
    <div class="section-heading">
        <span class="eyebrow">AI 友好的民俗知识库</span>
        <h1>中国民俗细则</h1>
        <p>
            按地区、节日、仪式和来源整理地方民俗资料。每个词条尽量保留摘要、步骤、禁忌、
            地区差异、FAQ、来源等级和待核实状态，方便读者浏览，也方便后续由 AI 协作维护。
        </p>
    </div>

    <form asp-controller="Home" asp-action="Search" method="get" class="search-form landing-search-shell">
        <div class="search-main-row">
            <input class="search-keyword-input" type="search" name="query" placeholder="搜索地区、节日、仪式、供品、禁忌或来源关键词" />
            <button type="submit" class="search-submit-button">搜索</button>
        </div>
    </form>

    <div class="hero-meta">
        <span>@Model.EntryCount 个词条</span>
        <span>@Model.LocationCount 个地区</span>
        <span>@Model.FestivalCount 个节日</span>
        <span>@Model.RitualCount 个仪式</span>
        <span>@Model.FeedbackCount 条投稿</span>
    </div>
</section>

<section class="content-section browse-grid" aria-label="知识库浏览入口">
    <article class="section-panel">
        <span class="footer-label">按地区</span>
        <h2>从地方进入</h2>
        <p>适合查某个省、市、乡镇或村落已收录的民俗资料。</p>
        <a class="text-link" asp-controller="Places" asp-action="Index">浏览地区</a>
    </article>
    <article class="section-panel">
        <span class="footer-label">按节日</span>
        <h2>从时间节点进入</h2>
        <p>适合比较同一节日下不同地区的做法差异。</p>
        <a class="text-link" asp-controller="Festivals" asp-action="Index">浏览节日</a>
    </article>
    <article class="section-panel">
        <span class="footer-label">按仪式</span>
        <h2>从具体做法进入</h2>
        <p>适合直接查看流程、材料、禁忌和常见问答。</p>
        <a class="text-link" asp-controller="Rituals" asp-action="Index">浏览仪式</a>
    </article>
    <article class="section-panel">
        <span class="footer-label">投稿入口</span>
        <h2>补充或纠错</h2>
        <p>可以提交新线索、来源、地区差异，也可以纠正现有词条。</p>
        <a class="text-link" asp-controller="Submit" asp-action="Create">提交资料</a>
    </article>
</section>

<section class="content-section">
    <div class="section-heading">
        <span class="eyebrow">最新收录</span>
        <h2>最近更新的词条</h2>
    </div>
    <div class="result-grid">
        @foreach (var entry in Model.LatestEntries)
        {
            <article class="surface-card">
                <div class="surface-link-head">
                    <div>
                        <span class="footer-label">@entry.ContentType</span>
                        <h3>@entry.Title</h3>
                    </div>
                    <span class="pill">@entry.ReviewStatus</span>
                </div>
                <p>@entry.Summary</p>
                <div class="meta-list">
                    <span>更新 @entry.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd")</span>
                    <span>置信度 @entry.ConfidenceLevel</span>
                </div>
                <a class="text-link" asp-controller="Entries" asp-action="Details" asp-route-slug="@entry.Slug">查看词条</a>
            </article>
        }
    </div>
</section>

<section class="content-section split-layout">
    <section class="section-panel">
        <div class="section-heading">
            <span class="eyebrow">地区入口</span>
            <h2>按地区浏览</h2>
        </div>
        <ul class="compact-list link-list">
            @foreach (var region in Model.FeaturedLocations)
            {
                <li>
                    <a asp-controller="Places" asp-action="Details" asp-route-slug="@region.Slug">@region.FullPath</a>
                </li>
            }
        </ul>
    </section>

    <section class="section-panel">
        <div class="section-heading">
            <span class="eyebrow">节日入口</span>
            <h2>按节日浏览</h2>
        </div>
        <ul class="compact-list link-list">
            @foreach (var festival in Model.FeaturedFestivals)
            {
                <li>
                    <a asp-controller="Festivals" asp-action="Details" asp-route-slug="@festival.Slug">@festival.Name</a>
                    <span class="muted">@festival.LunarLabel</span>
                </li>
            }
        </ul>
    </section>
</section>

<section class="content-section split-layout">
    <section class="section-panel">
        <div class="section-heading">
            <span class="eyebrow">热门词条</span>
            <h2>可优先查看的代表记录</h2>
        </div>
        <ul class="compact-list link-list">
            @foreach (var entry in Model.PopularEntries)
            {
                <li>
                    <a asp-controller="Entries" asp-action="Details" asp-route-slug="@entry.Slug">@entry.Title</a>
                    <span class="muted">@entry.Summary</span>
                </li>
            }
        </ul>
    </section>

    <section class="section-panel">
        <div class="section-heading">
            <span class="eyebrow">热门标签</span>
            <h2>常见检索词</h2>
        </div>
        <div class="chip-row">
            @foreach (var term in Model.PopularTerms)
            {
                <a class="pill" asp-controller="Entries" asp-action="Index" asp-route-tag="@term">@term</a>
            }
        </div>
    </section>
</section>
