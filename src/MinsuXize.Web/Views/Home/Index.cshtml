@model MinsuXize.Web.ViewModels.HomePageViewModel

<section class="launch-hero search-landing">
    <div class="hero-copy landing-copy">
        <span class="eyebrow">面向公众开放</span>
        <h1>浏览各地仍在流传的习俗做法，也欢迎一起补充和纠错</h1>
        <p class="hero-lead">
            这里收录的是地方习俗的公开资料。你可以先浏览现有内容，
            了解某一做法发生在什么地方、什么时节、有哪些流程和讲究；
            如果你掌握更多线索，也可以直接补充给我们。
        </p>

        <div class="hero-actions">
            <a class="button-primary" asp-controller="Entries" asp-action="Index">进入习俗浏览</a>
            <a class="button-secondary" asp-controller="Submit" asp-action="Create">提交补充或纠错</a>
        </div>

        <div class="hero-meta">
            <span>@Model.EntryCount 条公开记录</span>
            <span>@Model.LocationCount 个地区线索</span>
            <span>@Model.FestivalCount 个节令锚点</span>
            <span>@Model.FeedbackCount 条补充记录</span>
        </div>
    </div>
</section>

<section class="content-section stats-grid">
    <article class="surface-card">
        <span class="footer-label">先看什么</span>
        <h3>从公开记录开始</h3>
        <p>首页优先展示已经整理好的条目，帮助你快速进入浏览，不需要先理解复杂分类。</p>
    </article>
    <article class="surface-card">
        <span class="footer-label">怎么找</span>
        <h3>按关键词和地区查</h3>
        <p>你可以通过做法、节令、供品、参与者或地区来查找，更快找到感兴趣的内容。</p>
    </article>
    <article class="surface-card">
        <span class="footer-label">怎么参与</span>
        <h3>补充真实线索</h3>
        <p>哪怕只知道一个地方、一个做法细节或一条来源说明，也可以成为有价值的补充。</p>
    </article>
</section>

<section class="content-section page-header">
    <span class="eyebrow">持续建设中</span>
    <h2>目前展示的是第一批已整理内容</h2>
    <p>页面和资料都还在陆续补充。你看到的内容不代表已经收齐，只是先把可以公开浏览的部分整理出来，方便更多人查看和补正。</p>
</section>

<section class="content-section">
    <div class="section-heading">
        <span class="eyebrow">精选内容</span>
        <h2>可以先从这些条目开始浏览</h2>
        <p>这些是目前已经整理出的代表性条目，适合先了解页面结构和资料呈现方式。</p>
    </div>

    <div class="result-grid">
        @foreach (var entry in Model.FeaturedEntries)
        {
            <article class="surface-card">
                <div class="surface-link-head">
                    <div>
                        <span class="footer-label">公开条目</span>
                        <h3>@entry.Title</h3>
                    </div>
                    <span class="pill">@entry.InheritanceStatus</span>
                </div>
                <p>@entry.Summary</p>
                <div class="meta-list">
                    <span>整理版本 @entry.Version</span>
                    <span>更新于 @entry.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd")</span>
                </div>
                <a class="text-link" asp-controller="Entries" asp-action="Details" asp-route-id="@entry.Id">查看详情</a>
            </article>
        }
    </div>
</section>

<section class="content-section split-layout">
    <section class="section-panel">
        <div class="section-heading">
            <span class="eyebrow">按地区看</span>
            <h2>从地方线索进入内容</h2>
            <p>如果你更关心某个地方的风俗，可以先从地区入口查看，再进入具体条目。</p>
        </div>

        <div class="result-grid">
            @foreach (var region in Model.FeaturedLocations)
            {
                <article class="surface-card">
                    <span class="footer-label">地区线索</span>
                    <h3>@region.Name</h3>
                    <p>@region.Summary</p>
                    <a class="text-link" asp-controller="Regions" asp-action="Details" asp-route-id="@region.Id">查看地区页</a>
                </article>
            }
        </div>
    </section>

    <section class="section-panel">
        <div class="section-heading">
            <span class="eyebrow">按节令看</span>
            <h2>也可以从时间节点进入</h2>
            <p>一些做法与春节、清明、秋收等节令密切相关，按时间节点浏览会更直观。</p>
        </div>

        <ul class="compact-list">
            @foreach (var festival in Model.FeaturedFestivals)
            {
                <li>
                    <strong>@festival.Name</strong>，@festival.LunarLabel
                </li>
            }
        </ul>

        <div class="utility-actions">
            <a class="button-secondary" asp-controller="Festivals" asp-action="Index">查看节令目录</a>
            <a class="button-primary" asp-controller="Submit" asp-action="Create">补充相关线索</a>
        </div>
    </section>
</section>

<section class="content-section page-header">
    <span class="eyebrow">参与补充</span>
    <h2>如果你知道得更多，欢迎直接告诉我们</h2>
    <div class="meta-list">
        <span>可补充地区信息</span>
        <span>可补充流程细节</span>
        <span>可补充来源说明</span>
        <span>可指出错误或遗漏</span>
    </div>
</section>
