@model MinsuXize.Web.ViewModels.EntrySearchViewModel

<section class="page-header">
    <nav class="breadcrumb-line" aria-label="面包屑">
        <a asp-controller="Home" asp-action="Index">首页</a>
        <span>/</span>
        <span>@(Model.ContentType == "ritual" ? "仪式" : "词条")</span>
    </nav>
    <span class="eyebrow">结构化词条</span>
    <h1>@(Model.ContentType == "ritual" ? "仪式列表" : "民俗词条")</h1>
    <p>按地区、内容类型、节日和标签筛选。列表只显示摘要和关键元信息，详情页保留流程、地区差异、FAQ 和来源。</p>
    @if (!string.IsNullOrWhiteSpace(Model.SelectedRegionLabel))
    {
        <div class="meta-list">
            <span>当前地区：@Model.SelectedRegionLabel</span>
        </div>
    }
</section>

<section class="content-section search-shell">
    <form asp-action="Index" method="get" class="search-form">
        <div class="search-main-row">
            <input class="search-keyword-input" type="search" name="keyword" value="@Model.Keyword" placeholder="搜索做法、供品、禁忌、地区、来源或口述关键词" />
            <button type="submit" class="search-submit-button">筛选</button>
        </div>
        <div class="search-filter-row">
            <select name="regionId" class="search-select-input">
                <option value="">不限地区</option>
                @foreach (var option in Model.RegionOptions)
                {
                    <option value="@option.Value" selected="@option.Selected">@option.Text</option>
                }
            </select>
            <select name="contentType" class="search-select-input">
                <option value="">不限类型</option>
                @foreach (var option in Model.ContentTypeOptions)
                {
                    <option value="@option.Value" selected="@option.Selected">@option.Text</option>
                }
            </select>
            <select name="festivalId" class="search-select-input">
                <option value="">不限节日</option>
                @foreach (var option in Model.FestivalOptions)
                {
                    <option value="@option.Value" selected="@option.Selected">@option.Text</option>
                }
            </select>
            <select name="tag" class="search-select-input">
                <option value="">不限标签</option>
                @foreach (var option in Model.TagOptions)
                {
                    <option value="@option.Value" selected="@option.Selected">@option.Text</option>
                }
            </select>
        </div>
    </form>
</section>

<section class="content-section">
    <div class="section-heading">
        <span class="eyebrow">检索结果</span>
        <h2>共找到 @Model.Entries.Count 条记录</h2>
    </div>

    @if (Model.Entries.Count == 0)
    {
        <div class="empty-state">
            <h3>暂时没有匹配结果</h3>
            <p>可以缩短关键词、放宽筛选条件，或提交一条新的补充线索。</p>
            <div class="utility-actions">
                <a class="button-secondary" asp-controller="Submit" asp-action="Create">提交补充</a>
                <a class="button-primary" asp-controller="Home" asp-action="Index">返回首页</a>
            </div>
        </div>
    }
    else
    {
        <div class="result-grid">
            @foreach (var entry in Model.Entries)
            {
                var region = Model.RegionsById[entry.RegionId];
                var festival = Model.FestivalsById[entry.FestivalId];

                <article class="surface-card">
                    <div class="surface-link-head">
                        <div>
                            <span class="footer-label">@entry.ContentType</span>
                            <h3>@entry.Title</h3>
                        </div>
                        <span class="pill">@entry.ReviewStatus</span>
                    </div>
                    <p>@entry.Summary</p>
                    <div class="meta-list">
                        <span>@region.FullPath</span>
                        <span>@festival.Name</span>
                        <span>置信度 @entry.ConfidenceLevel</span>
                    </div>
                    <div class="chip-row">
                        @foreach (var tag in entry.Tags.Take(5))
                        {
                            <a class="pill" asp-action="Index" asp-route-tag="@tag">@tag</a>
                        }
                    </div>
                    <a class="text-link" asp-action="Details" asp-route-slug="@entry.Slug">查看详情</a>
                </article>
            }
        </div>
    }
</section>
