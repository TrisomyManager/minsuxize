@model MinsuXize.Web.ViewModels.EntryDetailsViewModel

<section class="page-header">
    <nav class="breadcrumb-line" aria-label="面包屑">
        <a asp-controller="Home" asp-action="Index">首页</a>
        <span>/</span>
        <a asp-controller="Places" asp-action="Details" asp-route-slug="@Model.Region.Slug">@Model.Region.Name</a>
        <span>/</span>
        <a asp-controller="Festivals" asp-action="Details" asp-route-slug="@Model.Festival.Slug">@Model.Festival.Name</a>
        <span>/</span>
        <span>@Model.Entry.Title</span>
    </nav>
    <span class="eyebrow">@Model.Entry.ContentType</span>
    <h1>@Model.Entry.Title</h1>
    <p>@Model.Entry.Summary</p>
    <div class="meta-list">
        <span>@Model.Region.FullPath</span>
        <span>@Model.Festival.Name | @Model.Festival.LunarLabel</span>
        <span>审核：@Model.Entry.ReviewStatus</span>
        <span>置信度：@Model.Entry.ConfidenceLevel</span>
        <span>更新：@Model.Entry.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd")</span>
    </div>
</section>

<section class="content-section story-grid">
    <article class="entry-story">
        <section class="detail-block">
            <h2>摘要</h2>
            <p>@Model.Entry.Summary</p>
        </section>

        <section class="detail-block">
            <h2>基本信息</h2>
            <dl class="definition-list">
                <dt>标题</dt>
                <dd>@Model.Entry.Title</dd>
                <dt>Slug</dt>
                <dd>@Model.Entry.Slug</dd>
                <dt>ContentType</dt>
                <dd>@Model.Entry.ContentType</dd>
                <dt>地区</dt>
                <dd>@Model.Region.FullPath</dd>
                <dt>材料</dt>
                <dd>@string.Join("、", Model.Entry.ItemsUsed)</dd>
                <dt>存续状态</dt>
                <dd>@Model.Entry.InheritanceStatus</dd>
            </dl>
        </section>

        @if (Model.Entry.Preparations.Count > 0)
        {
            <section class="detail-block">
                <h2>准备事项</h2>
                <ul class="compact-list">
                    @foreach (var item in Model.Entry.Preparations)
                    {
                        <li>@item</li>
                    }
                </ul>
            </section>
        }

        <section class="detail-block">
            <h2>步骤</h2>
            <ol class="ordered-list">
                @foreach (var step in Model.Entry.RitualProcess)
                {
                    <li>@step</li>
                }
            </ol>
        </section>

        <section class="detail-block">
            <h2>地区差异</h2>
            @if (Model.Entry.RegionalDifferences.Count == 0)
            {
                <p class="muted">暂无可公开展示的地区差异，欢迎补充。</p>
            }
            else
            {
                <ul class="compact-list">
                    @foreach (var item in Model.Entry.RegionalDifferences)
                    {
                        <li>@item</li>
                    }
                </ul>
            }
        </section>

        <section class="detail-block">
            <h2>禁忌与注意事项</h2>
            <ul class="compact-list">
                @foreach (var taboo in Model.Entry.Taboos)
                {
                    <li>@taboo</li>
                }
            </ul>
        </section>

        <section class="detail-block">
            <h2>背景与含义</h2>
            <div class="split-layout">
                <section>
                    <h3>历史渊源</h3>
                    <p>@Model.Entry.HistoricalOrigin</p>
                </section>
                <section>
                    <h3>文化含义</h3>
                    <p>@Model.Entry.SymbolicMeaning</p>
                </section>
            </div>
        </section>

        <section class="detail-block">
            <h2>FAQ</h2>
            @if (Model.Faqs.Count == 0)
            {
                <p class="muted">暂无问答，欢迎补充常见问题。</p>
            }
            else
            {
                <div class="faq-list">
                    @foreach (var faq in Model.Faqs)
                    {
                        <article>
                            <h3>@faq.Question</h3>
                            <p>@faq.Answer</p>
                        </article>
                    }
                </div>
            }
        </section>

        <section class="detail-block">
            <h2>来源说明</h2>
            @if (Model.Sources.Count == 0)
            {
                <p class="muted">这条记录的来源说明仍在补充中。</p>
            }
            else
            {
                <ul class="source-list">
                    @foreach (var source in Model.Sources)
                    {
                        <li>
                            <div class="surface-link-head">
                                <div>
                                    <span class="footer-label">@source.SourceType</span>
                                    <h3>@source.Title</h3>
                                </div>
                                <span class="pill">@source.SourceLevel</span>
                            </div>
                            <p>@source.Citation</p>
                            <p class="muted">记录者：@source.Contributor；记录时间：@source.RecordedAt</p>
                            @if (!string.IsNullOrWhiteSpace(source.Notes))
                            {
                                <p class="helper-copy">@source.Notes</p>
                            }
                        </li>
                    }
                </ul>
            }
        </section>
    </article>

    <aside class="entry-sidebar">
        <section class="section-panel">
            <span class="eyebrow">结构化状态</span>
            <h2>词条元信息</h2>
            <ul class="info-list">
                <li>ReviewStatus：@Model.Entry.ReviewStatus</li>
                <li>ConfidenceLevel：@Model.Entry.ConfidenceLevel</li>
                <li>SourceGrade：@Model.Entry.SourceGrade</li>
                <li>版本：@Model.Entry.Version</li>
                <li>维护者：@Model.Entry.CreatedBy</li>
                <li>最近更新：@Model.Entry.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</li>
            </ul>
            <a class="text-link" href="@($"/api/entries/{Model.Entry.Slug}.json")">查看 JSON</a>
        </section>

        <section class="section-panel">
            <span class="eyebrow">补充入口</span>
            <h2>我要补充或纠错</h2>
            <p>如果你知道更准确的流程、材料、禁忌、地区差异或来源线索，可以直接关联本词条提交。</p>
            <a class="button-primary" asp-controller="Submit" asp-action="Create" asp-route-entryId="@Model.Entry.Id">补充这条词条</a>
        </section>

        <section class="section-panel">
            <span class="eyebrow">相关推荐</span>
            <h2>继续查看</h2>
            @if (Model.RelatedEntries.Count == 0)
            {
                <p class="muted">暂无相关推荐。</p>
            }
            else
            {
                <ul class="compact-list link-list">
                    @foreach (var entry in Model.RelatedEntries)
                    {
                        <li>
                            <a asp-controller="Entries" asp-action="Details" asp-route-slug="@entry.Slug">@entry.Title</a>
                        </li>
                    }
                </ul>
            }
        </section>

        <section class="section-panel">
            <span class="eyebrow">相关入口</span>
            <div class="utility-actions">
                <a class="button-secondary" asp-controller="Places" asp-action="Details" asp-route-slug="@Model.Region.Slug">地区页</a>
                <a class="button-secondary" asp-controller="Festivals" asp-action="Details" asp-route-slug="@Model.Festival.Slug">节日页</a>
            </div>
        </section>
    </aside>
</section>
