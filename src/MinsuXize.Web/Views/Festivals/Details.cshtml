@model MinsuXize.Web.ViewModels.FestivalDetailsViewModel

<section class="page-header">
    <nav class="breadcrumb-line" aria-label="面包屑">
        <a asp-controller="Home" asp-action="Index">首页</a>
        <span>/</span>
        <a asp-controller="Festivals" asp-action="Index">节日</a>
        <span>/</span>
        <span>@Model.Festival.Name</span>
    </nav>
    <span class="eyebrow">@Model.Festival.Category</span>
    <h1>@Model.Festival.Name</h1>
    <p>@Model.Festival.Summary</p>
    <div class="meta-list">
        <span>@Model.Festival.LunarLabel</span>
        <span>@Model.Entries.Count 条相关词条</span>
    </div>
</section>

<section class="content-section split-layout">
    <section class="section-panel">
        <span class="eyebrow">核心主题</span>
        <h2>可检索主题</h2>
        <div class="chip-row">
            @foreach (var topic in Model.Festival.CoreTopics)
            {
                <a class="pill" asp-controller="Entries" asp-action="Index" asp-route-keyword="@topic">@topic</a>
            }
        </div>
    </section>
    <section class="section-panel">
        <span class="eyebrow">投稿</span>
        <h2>补充节日差异</h2>
        <p>如果你知道某地在这个节日中的具体做法、禁忌或来源线索，可以提交补充。</p>
        <a class="button-primary" asp-controller="Submit" asp-action="Create">提交资料</a>
    </section>
</section>

<section class="content-section">
    <div class="section-heading">
        <span class="eyebrow">相关词条</span>
        <h2>@Model.Festival.Name 下的民俗记录</h2>
    </div>
    @if (Model.Entries.Count == 0)
    {
        <div class="empty-state">
            <p>这个节日还没有公开词条。</p>
        </div>
    }
    else
    {
        <div class="result-grid">
            @foreach (var entry in Model.Entries)
            {
                var region = Model.RegionsById[entry.RegionId];
                <article class="surface-card">
                    <span class="footer-label">@entry.ContentType</span>
                    <h3>@entry.Title</h3>
                    <p>@entry.Summary</p>
                    <div class="meta-list">
                        <span>@region.FullPath</span>
                        <span>@entry.ReviewStatus</span>
                    </div>
                    <a class="text-link" asp-controller="Entries" asp-action="Details" asp-route-slug="@entry.Slug">查看词条</a>
                </article>
            }
        </div>
    }
</section>
