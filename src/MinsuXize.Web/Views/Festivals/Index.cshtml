@model IReadOnlyList<MinsuXize.Web.Models.Festival>

<section class="page-header">
    <nav class="breadcrumb-line" aria-label="面包屑">
        <a asp-controller="Home" asp-action="Index">首页</a>
        <span>/</span>
        <span>节日</span>
    </nav>
    <span class="eyebrow">Festivals</span>
    <h1>按节日浏览</h1>
    <p>从春节、清明、中元等时间节点进入，比较不同地区在同一节日下的仪式、材料和禁忌差异。</p>
</section>

<section class="content-section">
    <div class="result-grid">
        @foreach (var festival in Model)
        {
            <article class="surface-card">
                <span class="footer-label">@festival.Category</span>
                <h2>@festival.Name</h2>
                <p>@festival.Summary</p>
                <div class="meta-list">
                    <span>@festival.LunarLabel</span>
                    <span>更新 @festival.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd")</span>
                </div>
                <div class="chip-row">
                    @foreach (var topic in festival.CoreTopics.Take(5))
                    {
                        <span class="pill">@topic</span>
                    }
                </div>
                <a class="text-link" asp-action="Details" asp-route-slug="@festival.Slug">查看节日页</a>
            </article>
        }
    </div>
</section>
