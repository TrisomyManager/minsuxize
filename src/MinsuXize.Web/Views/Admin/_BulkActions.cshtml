@model MinsuXize.Web.ViewModels.AdminDashboardViewModel

<div class="bulk-actions-panel">
    <h3>批量操作</h3>
    <form asp-action="BulkReview" method="post" class="bulk-form" id="bulkForm">
        <input type="hidden" name="submissionIds" id="bulkSubmissionIds" value="" />
        
        <div class="bulk-controls">
            <div class="bulk-checkbox">
                <input type="checkbox" id="selectAll" />
                <label for="selectAll">全选当前页</label>
            </div>
            
            <div class="bulk-status">
                <label for="bulkStatus">批量设置状态：</label>
                <select name="status" id="bulkStatus" class="field-input">
                    <option value="0">待审核</option>
                    <option value="1">需要修改</option>
                    <option value="2">已通过</option>
                    <option value="3">已拒绝</option>
                </select>
            </div>
            
            <div class="bulk-note">
                <label for="bulkReviewerNote">批量审核意见：</label>
                <textarea name="reviewerNote" id="bulkReviewerNote" rows="3" class="field-input" placeholder="请输入批量审核意见..."></textarea>
            </div>
            
            <div class="bulk-submit">
                <button type="submit" class="button-primary" onclick="return validateBulkSelection()">执行批量操作</button>
                <button type="button" class="button-secondary" onclick="clearBulkSelection()">清空选择</button>
            </div>
        </div>
    </form>
</div>

<script>
    // 全选/取消全选
    document.getElementById('selectAll').addEventListener('change', function(e) {
        const checkboxes = document.querySelectorAll('.submission-checkbox');
        checkboxes.forEach(cb => cb.checked = e.target.checked);
        updateBulkSelection();
    });
    
    // 单个复选框变化时更新
    document.addEventListener('change', function(e) {
        if (e.target.classList.contains('submission-checkbox')) {
            updateBulkSelection();
        }
    });
    
    // 更新隐藏的提交ID列表
    function updateBulkSelection() {
        const checkboxes = document.querySelectorAll('.submission-checkbox:checked');
        const ids = Array.from(checkboxes).map(cb => cb.value);
        document.getElementById('bulkSubmissionIds').value = ids.join(',');
        
        // 更新全选状态
        const allCheckboxes = document.querySelectorAll('.submission-checkbox');
        const selectAll = document.getElementById('selectAll');
        selectAll.checked = allCheckboxes.length > 0 && checkboxes.length === allCheckboxes.length;
        selectAll.indeterminate = checkboxes.length > 0 && checkboxes.length < allCheckboxes.length;
    }
    
    // 验证是否有选择
    function validateBulkSelection() {
        const ids = document.getElementById('bulkSubmissionIds').value;
        if (!ids) {
            alert('请至少选择一个投稿进行操作');
            return false;
        }
        return confirm(`确定要对 ${ids.split(',').length} 个投稿执行批量操作吗？`);
    }
    
    // 清空选择
    function clearBulkSelection() {
        const checkboxes = document.querySelectorAll('.submission-checkbox');
        checkboxes.forEach(cb => cb.checked = false);
        document.getElementById('bulkSubmissionIds').value = '';
        document.getElementById('selectAll').checked = false;
        document.getElementById('selectAll').indeterminate = false;
    }
    
    // 初始化
    document.addEventListener('DOMContentLoaded', function() {
        updateBulkSelection();
    });
</script>

<style>
.bulk-actions-panel {
    background: #f8f9fa;
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 2rem;
    border: 1px solid #dee2e6;
}

.bulk-actions-panel h3 {
    margin-top: 0;
    margin-bottom: 1rem;
    color: #495057;
    border-bottom: 1px solid #dee2e6;
    padding-bottom: 0.5rem;
}

.bulk-controls {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.bulk-checkbox {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.bulk-checkbox input[type="checkbox"] {
    width: 1.2rem;
    height: 1.2rem;
}

.bulk-checkbox label {
    font-weight: 500;
    color: #495057;
}

.bulk-status, .bulk-note {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}

.bulk-status label, .bulk-note label {
    font-weight: 500;
    color: #495057;
}

.bulk-submit {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
}

.submission-checkbox {
    margin-right: 0.5rem;
}
</style>