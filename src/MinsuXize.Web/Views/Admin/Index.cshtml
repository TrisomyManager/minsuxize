@model MinsuXize.Web.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "投稿审核";

    var pendingCount = Model.Submissions.Count(item => item.Status == MinsuXize.Web.Models.SubmissionStatus.PendingReview);
    var revisionCount = Model.Submissions.Count(item => item.Status == MinsuXize.Web.Models.SubmissionStatus.NeedsRevision);
    var approvedCount = Model.Submissions.Count(item => item.Status == MinsuXize.Web.Models.SubmissionStatus.Approved);

    string GetStatusText(MinsuXize.Web.Models.SubmissionStatus status) =>
        status switch
        {
            MinsuXize.Web.Models.SubmissionStatus.PendingReview => "待审核",
            MinsuXize.Web.Models.SubmissionStatus.NeedsRevision => "退回补充",
            MinsuXize.Web.Models.SubmissionStatus.Approved => "已确认",
            MinsuXize.Web.Models.SubmissionStatus.Rejected => "已归档",
            _ => status.ToString()
        };

    string GetStatusClass(MinsuXize.Web.Models.SubmissionStatus status) =>
        status switch
        {
            MinsuXize.Web.Models.SubmissionStatus.PendingReview => "pending",
            MinsuXize.Web.Models.SubmissionStatus.NeedsRevision => "revision",
            MinsuXize.Web.Models.SubmissionStatus.Approved => "approved",
            MinsuXize.Web.Models.SubmissionStatus.Rejected => "rejected",
            _ => "pending"
        };
}

<section class="page-header">
    <span class="eyebrow">投稿审核</span>
    <h1>投稿处理队列</h1>
    <p>集中查看读者提交的补充和纠错，记录处理意见，并完成最基本的状态调整。</p>
    <div class="page-actions">
        <a class="button-primary" asp-controller="Submit" asp-action="Create">新建测试投稿</a>
        <a class="button-secondary" asp-action="Entries">词条维护</a>
        <a class="button-secondary" asp-controller="Home" asp-action="Index">公开页面</a>
    </div>
</section>

<section class="content-section stats-grid">
    <article class="surface-card">
        <span class="footer-label">待审核</span>
        <h2>@pendingCount</h2>
        <p>等待首次查看和处理的投稿。</p>
    </article>
    <article class="surface-card">
        <span class="footer-label">退回补充</span>
        <h2>@revisionCount</h2>
        <p>仍需补充来源或关键细节的投稿。</p>
    </article>
    <article class="surface-card">
        <span class="footer-label">已确认</span>
        <h2>@approvedCount</h2>
        <p>已经确认可继续整理的投稿记录。</p>
    </article>
</section>

@if (Model.Submissions.Any())
{
    <section class="content-section">
        <div class="section-heading">
            <span class="eyebrow">当前队列</span>
            <h2>所有投稿记录</h2>
        </div>

        <div class="dashboard-grid">
            @foreach (var item in Model.Submissions)
            {
                var region = Model.RegionsById[item.RegionId];
                var festival = Model.FestivalsById[item.FestivalId];

                <article class="surface-card submission-card">
                    <div class="submission-head">
                        <div>
                            <span class="status-chip @GetStatusClass(item.Status)">@GetStatusText(item.Status)</span>
                            <h3>@item.Title</h3>
                        </div>
                        <div class="meta-list">
                            <span>#@item.Id</span>
                            <span>@item.ContentType</span>
                        </div>
                    </div>

                    <div class="submission-body">
                        <p><strong>提交人：</strong>@item.ContributorName @(!string.IsNullOrWhiteSpace(item.Contact) ? $" | {item.Contact}" : string.Empty)</p>
                        <p><strong>地区：</strong>@region.FullPath</p>
                        <p><strong>节日：</strong>@festival.Name</p>
                        <p><strong>摘要：</strong>@item.Summary</p>
                        <p><strong>来源说明：</strong>@item.SourceSummary</p>
                        @if (!string.IsNullOrWhiteSpace(item.ChangeLog))
                        {
                            <p><strong>补充说明：</strong>@item.ChangeLog</p>
                        }
                        <div class="utility-row">
                            <span class="muted">提交：@item.SubmittedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                            <a class="text-link" asp-action="History" asp-route-id="@item.Id">处理记录</a>
                        </div>
                    </div>

                    <form asp-action="Review" method="post" class="review-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@item.Id" />
                        <div class="field-group">
                            <label class="field-label" for="reviewerNote-@item.Id">处理备注</label>
                            <textarea id="reviewerNote-@item.Id" name="reviewerNote" rows="3" class="field-input" placeholder="记录判断依据、待补充项或处理结论。">@item.ReviewerNote</textarea>
                        </div>
                        <div class="utility-actions">
                            <button type="submit" class="button-secondary" name="status" value="@MinsuXize.Web.Models.SubmissionStatus.NeedsRevision">退回补充</button>
                            <button type="submit" class="button-danger" name="status" value="@MinsuXize.Web.Models.SubmissionStatus.Rejected">归档</button>
                            <button type="submit" class="button-primary" name="status" value="@MinsuXize.Web.Models.SubmissionStatus.Approved">确认</button>
                        </div>
                    </form>
                </article>
            }
        </div>
    </section>
}
else
{
    <div class="content-section empty-state">
        <h3>当前没有待处理投稿</h3>
        <p>队列已经清空，可以回到公开页面继续浏览，或创建一条测试投稿验证流程。</p>
        <div class="utility-actions">
            <a class="button-primary" asp-controller="Submit" asp-action="Create">创建测试投稿</a>
            <a class="button-secondary" asp-controller="Home" asp-action="Index">返回首页</a>
        </div>
    </div>
}
