@model MinsuXize.Web.ViewModels.RegionDetailsViewModel
@{
    ViewData["Title"] = Model.Region.Name;
}

<section class="page-header">
    <span class="eyebrow">@Model.Region.Type</span>
    <h1>@Model.Region.Name</h1>
    <p>@Model.Region.Summary</p>
    <div class="meta-list">
        <span>@Model.Region.FullPath</span>
        @if (Model.DescendantRegionCount > 0)
        {
            <span>下级节点 @Model.DescendantRegionCount 个</span>
        }
    </div>
</section>

<section class="content-section split-layout">
    <section class="section-panel">
        <span class="eyebrow">地区重点</span>
        <h2>地区文化焦点</h2>
        <p>@Model.Region.CulturalFocus</p>
        <div class="pill-grid">
            @foreach (var item in Model.Region.Highlights)
            {
                <span class="pill">@item</span>
            }
        </div>
        @if (Model.ParentRegion is not null)
        {
            <p class="helper-copy">
                上级地区：
                <a class="text-link" asp-action="Details" asp-route-id="@Model.ParentRegion.Id">@Model.ParentRegion.Name</a>
            </p>
        }
    </section>

    <section class="section-panel">
        <span class="eyebrow">下级地区</span>
        <h2>下级地区</h2>
        @if (Model.ChildRegions.Count == 0)
        {
            <div class="empty-state">
                <p>这个地区暂未细分到更下一级地点，后续会随资料整理继续补充。</p>
            </div>
        }
        else
        {
            <div class="result-grid">
                @foreach (var child in Model.ChildRegions)
                {
                    <a class="surface-link" asp-action="Details" asp-route-id="@child.Id">
                        <div class="surface-link-head">
                            <div>
                                <span class="footer-label">@child.Type</span>
                                <h3>@child.Name</h3>
                            </div>
                        </div>
                        <p>@child.Summary</p>
                    </a>
                }
            </div>
        }
    </section>
</section>

<section class="content-section">
    <div class="section-heading">
        <span class="eyebrow">关联条目</span>
        <h2>本地区及下级地区已收录条目</h2>
        <p>点击上级地区时，会一并聚合同一行政层级以下已经收录的民俗细则。</p>
    </div>

    @if (Model.Entries.Count == 0)
    {
        <div class="empty-state">
            <h3>这个地区还没有公开条目</h3>
            <p>如果你熟悉本地做法，可以提交一条线索，帮助补齐这个地区的记录。</p>
            <a class="button-primary" asp-controller="Submit" asp-action="Create">提交本地民俗线索</a>
        </div>
    }
    else
    {
        <div class="result-grid">
            @foreach (var entry in Model.Entries)
            {
                <article class="surface-card">
                    <span class="footer-label">民俗细则</span>
                    <h3>@entry.Title</h3>
                    <p>@entry.Summary</p>
                    <div class="chip-row">
                        <span class="pill">@entry.InheritanceStatus</span>
                        <span class="pill">v@(entry.Version)</span>
                    </div>
                    <a class="text-link" asp-controller="Entries" asp-action="Details" asp-route-id="@entry.Id">查看细则全文</a>
                </article>
            }
        </div>
    }
</section>
