<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 中国民俗细则</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MinsuXize.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="site-shell">
        <header class="site-header">
            <div class="shell-inner">
                <a class="brand-mark" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-kicker">Minsu</span>
                    <strong>中国民俗细则</strong>
                </a>
                <nav class="site-nav">
                    <a asp-controller="Regions" asp-action="Index">地区</a>
                    <a asp-controller="Festivals" asp-action="Index">节日</a>
                    <a asp-controller="Entries" asp-action="Index">民俗条目</a>
                    <a asp-controller="Submit" asp-action="Create">投稿</a>
                </nav>
            </div>
        </header>

        @if ((bool?)ViewData["IsAdminPage"] == true)
        {
            <div class="admin-strip">
                <div class="shell-inner admin-strip-inner">
                    <span>管理员审核页面</span>
                    <div class="admin-strip-actions">
                        @if (ViewData["AdminUsername"] is string adminUsername && !string.IsNullOrWhiteSpace(adminUsername))
                        {
                            <span>@adminUsername</span>
                        }
                        <form asp-controller="Manage" asp-action="Logout" method="post">
                            <button type="submit" class="admin-logout-button">退出登录</button>
                        </form>
                    </div>
                </div>
            </div>
        }

        <main role="main" class="shell-inner page-body">
            @RenderBody()
        </main>

        <footer class="site-footer">
            <div class="shell-inner footer-grid">
                <div>
                    <strong>中国民俗细则</strong>
                    <p>记录具体地方、具体日子、具体做法，让传统文化有据可依。</p>
                </div>
                <div>
                    <span class="footer-label">当前原型重点</span>
                    <p>前台浏览、结构化投稿、民俗条目页，以及独立管理员审核页。</p>
                </div>
            </div>
        </footer>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
