@using MinsuXize.Web.Options
@inject Microsoft.Extensions.Options.IOptions<SiteOptions> SiteOptions
@{
    var siteName = "中国民俗细则";
    var request = Context.Request;
    var pageTitle = ViewData["Title"]?.ToString();
    var metaDescription = ViewData["MetaDescription"]?.ToString() ?? "面向用户、搜索引擎与 AI 协作维护的结构化中国民俗知识库。";
    var metaKeywords = ViewData["MetaKeywords"]?.ToString() ?? "民俗,地方习俗,节日,仪式,民俗知识库";
    var metaRobots = ViewData["MetaRobots"]?.ToString() ?? "index, follow, max-image-preview:large";
    var fullTitle = string.IsNullOrWhiteSpace(pageTitle) ? siteName : $"{pageTitle} | {siteName}";
    var baseUrl = SiteOptions.Value.BaseUrl.TrimEnd('/') + "/";
    var canonicalUrl = ViewData["CanonicalUrl"]?.ToString();
    if (string.IsNullOrWhiteSpace(canonicalUrl))
    {
        canonicalUrl = new Uri(new Uri(baseUrl), $"{request.PathBase}{request.Path}").ToString();
    }
}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="@metaDescription" />
    <meta name="keywords" content="@metaKeywords" />
    <meta name="robots" content="@metaRobots" />
    <meta name="theme-color" content="#f6f0e4" />
    <meta name="format-detection" content="telephone=no" />
    <meta property="og:site_name" content="@siteName" />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="@fullTitle" />
    <meta property="og:description" content="@metaDescription" />
    <meta property="og:url" content="@canonicalUrl" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="@fullTitle" />
    <meta name="twitter:description" content="@metaDescription" />
    <title>@fullTitle</title>
    <link rel="canonical" href="@canonicalUrl" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="public-mode">
    <div class="site-shell">
        <header class="site-header">
            <div class="shell-inner header-row">
                <a class="brand-mark" asp-controller="Home" asp-action="Index" aria-label="返回中国民俗细则首页">
                    <span class="brand-kicker">结构化民俗知识库</span>
                    <strong>中国民俗细则</strong>
                    <span class="brand-note">按地区、节日、仪式和来源整理</span>
                </a>

                <nav class="site-nav" aria-label="主导航">
                    <a asp-controller="Home" asp-action="Index">首页</a>
                    <a asp-controller="Entries" asp-action="Index">词条</a>
                    <a asp-controller="Places" asp-action="Index">地区</a>
                    <a asp-controller="Festivals" asp-action="Index">节日</a>
                    <a asp-controller="Rituals" asp-action="Index">仪式</a>
                    <a asp-controller="Home" asp-action="About">关于</a>
                </nav>

                <div class="header-actions">
                    <a class="button-primary button-small" asp-controller="Submit" asp-action="Create">投稿</a>
                </div>
            </div>
        </header>

        <main role="main" class="shell-inner page-body">
            @RenderBody()
        </main>

        <footer class="site-footer">
            <div class="shell-inner footer-layout">
                <div>
                    <span class="eyebrow">持续整理中</span>
                    <h2>把地方民俗资料整理成可检索、可核对、可继续扩展的知识库</h2>
                    <p>
                        本站优先保留来源、更新时间、待核实状态和地区差异。内容不代表已经收齐，
                        也欢迎通过投稿入口补充真实线索、来源说明和纠错意见。
                    </p>
                </div>
                <div class="footer-column">
                    <span class="footer-label">浏览入口</span>
                    <a asp-controller="Entries" asp-action="Index">民俗词条</a>
                    <a asp-controller="Places" asp-action="Index">按地区浏览</a>
                    <a asp-controller="Festivals" asp-action="Index">按节日浏览</a>
                    <a asp-controller="Rituals" asp-action="Index">按仪式浏览</a>
                </div>
                <div class="footer-column">
                    <span class="footer-label">参与维护</span>
                    <a asp-controller="Submit" asp-action="Create">投稿与纠错</a>
                    <a asp-controller="Home" asp-action="SubmissionGuidelines">提交说明</a>
                    <a asp-controller="Home" asp-action="Privacy">隐私说明</a>
                    <a asp-controller="Home" asp-action="Terms">使用条款</a>
                </div>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
